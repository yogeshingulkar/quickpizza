# Target QuickPizza HTTP base URL
BASE_URL=http://localhost:3333

# gRPC tier (foundations/16.grpc.js)
BASE_GRPC_URL=localhost:3334

# Path to k6 scripts (../k6 in monorepo, ./k6 when extracted)
K6_ROOT=../k6

# k6 binary name or path
K6_PATH=k6

# Docker image for docker-compose.yml
QUICKPIZZA_IMAGE=ghcr.io/grafana/quickpizza-local:latest

# Browser tests
K6_BROWSER_HEADLESS=true

# Prometheus extension (extensions/02.prometheus-client.js)
# RW_URL=http://localhost:9090/api/v1/write
